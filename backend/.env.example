# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER_NAME.mongodb.net/wirtualnytrener?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb://localhost:27017/wirtualnytrener-test

# JWT Authentication
JWT_SECRET=your-super-secure-secret-key-minimum-32-characters-long
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=another-secure-refresh-token-secret-min-32-chars
JWT_REFRESH_EXPIRATION=30d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Dialogflow AI Integration
GOOGLE_DIALOGFLOW_KEY_FILE=./google-credentials-dialogflow.json
DIALOGFLOW_PROJECT_ID=your-dialogflow-project-id
DIALOGFLOW_AGENT_ID=your-agent-id

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# Frontend URL (for redirects, emails, etc.)
FRONTEND_URL=http://localhost:5173

# Email Service (optional, for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Application Name
APP_NAME=WirtualnyTrener
APP_VERSION=1.0.0
